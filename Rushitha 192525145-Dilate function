import cv2
import numpy as np
img = cv2.imread(r"C:\Users\SAIL\Documents\CV LAB\image.jpg")
if img is None:
    print("Error: Image not found. Check the path.")
    exit()
kernel = np.ones((5, 5), np.uint8)
dilated = cv2.dilate(img, kernel, iterations=1)
cv2.imshow("Original Color Image", img)
cv2.imshow("Dilated Color Image", dilated)
cv2.imwrite("color_dilated_image.jpg", dilated)
cv2.waitKey(0)
cv2.destroyAllWindows()
