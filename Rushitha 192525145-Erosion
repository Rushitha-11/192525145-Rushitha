import cv2
import numpy as np
img = cv2.imread(r"C:\Users\SAIL\Documents\CV LAB\image.jpg")
if img is None:
    print("Error: Image not found. Check the path.")
    exit()
kernel = np.ones((5, 5), np.uint8)
eroded = cv2.erode(img, kernel, iterations=1)
cv2.imshow("Original Color Image", img)
cv2.imshow("Eroded Color Image", eroded)
cv2.imwrite("color_eroded_image.jpg", eroded)
cv2.waitKey(0)
cv2.destroyAllWindows()
